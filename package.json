{
  "name": "openclaw-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Local dashboard for OpenClaw model orchestration",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "start:test-config": "OPENCLAW_CONFIG_PATH=./local-data/openclaw.test.json node src/index.js",
    "test": "node --test",
    "test:unit": "node --test",
    "test:smoke": "node scripts/run-regression.js",
    "test:regression": "npm run test:unit && npm run test:smoke",
    "ci": "npm run test:regression"
  }
}
